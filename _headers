# HTML/HTM 페이지: 항상 최신 버전 제공 (CDN 캐시 방지)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/*.htm
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

