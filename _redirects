# Whistle AI — Domain Routing (whistle-ai.com + GitHub Pages)
# Updated 2026-03-15: Beta Open + Global multi-language support

# Main page → global landing with auto-language detection
/ /whistle-main.html 200

# Korean manufacturer portal (Alibaba + voucher content)
/ko /whistle-landing.html 200
/ko/* /whistle-landing.html 200
/ko_made /whistle.html 200
/ko_made/* /whistle.html 200

# Global manufacturer portal → landing page first (app via /app)
/gb_made /whistle-main.html 200
/gb_made/* /whistle-main.html 200

# Global landing pages (English, no Alibaba/voucher content)
# Using directory-based routing to avoid Cloudflare Pretty URLs 308 redirect
/global /global-landing.html 200

# Buyer portal (multi-language landing)
/buyer /buyer-landing.html 200
/buyer/* /buyer-landing.html 200

# App portals (logged-in users)
# NOTE: Cloudflare Pretty URLs converts .html rewrites to 308 redirects.
# buyer.html renamed to buyer-app.html to avoid /buyer → buyer-landing chain.
/app/buyer /buyer-app.html 200
/app/buyer/* /buyer-app.html 200
/app /whistle.html 200
/app/* /whistle.html 200

# Admin
/admin /admin-portal.html 200

# Legal pages (renamed to avoid Cloudflare Pretty URLs redirect loop)
/terms /terms-of-service.html 200
/privacy /privacy-policy.html 200
/refund /refund-policy.html 200

# Beta open page (formerly pre-launch)
/prelaunch /whistle-prelaunch.html 200
/beta /whistle-prelaunch.html 200
